# Environment variables
# Copy this file to .env.local and fill in the values

# ─── Site ────────────────────────────────────────────────────────────────────

# Public URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Registration API ────────────────────────────────────────────────────────

# Shared secret for the public registration endpoint (x-public-register-key header)
PUBLIC_REGISTER_KEY=your-public-register-key-here

# ─── AWS SES (SMTP) ──────────────────────────────────────────────────────────
# Use SMTP credentials from the SES console (not IAM API keys).
# Generate at: AWS Console → SES → SMTP settings → Create SMTP credentials

AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SES_SECRET_ACCESS_KEY=your-smtp-password-here

# SES Configuration Set name (optional, for tracking/events)
SES_CONFIGURATION_SET=your-configuration-set-name

# Verified sender address (must match a verified identity/domain in SES)
SES_FROM_EMAIL=noreply@example.com

# Email address to receive contact form submissions
CONTACT_EMAIL=hello@example.com

# ─── Google reCAPTCHA v3 ─────────────────────────────────────────────────────
# Create keys at: https://www.google.com/recaptcha/admin
# Choose reCAPTCHA v3 and add your domains (e.g. example.com, localhost)
# Leave empty to disable reCAPTCHA verification during development.

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
